{
  "name": "zoo-aquarium-log",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest",
    "test:data": "node --test tests/facilities.test.mjs",
    "check:duplicates": "node scripts/find-duplicate-candidates.mjs",
    "check:links": "node scripts/check-source-urls.mjs",
    "test:rules": "firebase emulators:exec --only firestore --project demo-zoo-aquarium-log \"vitest --run --config vitest.rules.config.ts\"",
    "lint": "tsc -b --noEmit"
  },
  "dependencies": {
    "firebase": "^12.16.0",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/leaflet": "^1.9.21",
    "@types/leaflet.markercluster": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "firebase-tools": "^15.23.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
}
